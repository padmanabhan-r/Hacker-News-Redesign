# ElevenLabs SDK auth — used by Listen narration and HN++ Pod dialogue render
ELEVENLABS_API_KEY=

# Firecrawl scrape API — article extraction for Listen + Podcast bake
FIRECRAWL_API_KEY=

# Google Gemini Flash — Listen summary + Podcast dialogue script
GEMINI_API_KEY=

# Webhook secret for /api/podcast/cron manual trigger (Bearer or ?secret=)
# Same value must be set as a GitHub Actions secret if you trigger via curl.
CRON_SECRET=

# Cloudflare R2 — object storage for podcast episodes + Listen cache
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket (r2.dev or custom domain)
R2_PUBLIC_BASE_URL=
